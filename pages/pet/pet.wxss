/* pages/pet/pet.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFF 100%);
  padding: 30rpx;
  box-sizing: border-box;
}

/* 未绑定提示 */
.bind-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.bind-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.bind-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.bind-btn {
  width: 300rpx;
}

/* 创建界面 */
.create-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.create-icon {
  font-size: 150rpx;
  margin-bottom: 30rpx;
}

.create-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.create-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.pet-select {
  display: flex;
  gap: 40rpx;
  margin-bottom: 40rpx;
}

.pet-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 50rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 4rpx solid #eee;
  transition: all 0.3s;
}

.pet-option.active {
  border-color: #FF6B6B;
  background: #FFF5F5;
}

.pet-option-svg {
  width: 160rpx;
  height: 144rpx;
  margin-bottom: 10rpx;
}

.pet-name {
  font-size: 28rpx;
  color: #666;
}

.input-group {
  width: 100%;
  margin-bottom: 40rpx;
}

.pet-name-input {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 44rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  border: 2rpx solid #eee;
}

/* 宠物展示界面 */
.pet-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pet-tabs {
  display: flex;
  background: #fff;
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.pet-tab {
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  color: #999;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.pet-tab.active {
  background: #1A1A1A;
  color: #fff;
}

.pet-card {
  width: 100%;
  background: #fff;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.pet-image-wrapper {
  width: 100%;
  height: 400rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
}

.pet-image {
  width: 320rpx;
  height: 320rpx;
}

.hunger-overlay {
  position: absolute;
  top: 20rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.hunger-overlay-text {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: bold;
  background: rgba(255, 255, 255, 0.8);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.sad-overlay {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.sad-overlay-text {
  font-size: 24rpx;
  color: #999;
  background: rgba(255, 255, 255, 0.8);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.pet-name-display {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 40rpx;
}

.pet-name-display text {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

/* 好感度 */
.affection-section,
.hunger-section {
  margin-bottom: 35rpx;
}

.affection-header,
.hunger-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.affection-label,
.hunger-label {
  font-size: 28rpx;
  color: #666;
}

.affection-level {
  font-size: 24rpx;
  color: #FF6B6B;
  background: #FFF5F5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.hunger-status {
  font-size: 24rpx;
}

.hunger-status.normal {
  color: #FFA500;
}

.hunger-status.full {
  color: #52C41A;
}

.affection-bar,
.hunger-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.affection-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B, #FF8E53);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.hunger-fill {
  height: 100%;
  background: linear-gradient(90deg, #52C41A, #95DE64);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.hunger-fill.low {
  background: linear-gradient(90deg, #FF4D4F, #FF7875);
}

.affection-percent,
.hunger-percent {
  position: absolute;
  right: 0;
  top: 24rpx;
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.action-btns {
  display: flex;
  gap: 30rpx;
  margin-top: 50rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: #f9f9f9;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.action-btn:active {
  transform: scale(0.95);
}

.feed-btn {
  background: #FFF5F5;
}

.pet-btn {
  background: #F0F5FF;
}

.action-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.action-label {
  font-size: 28rpx;
  color: #666;
}

/* 解锁提示 */
.unlock-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  padding: 30rpx;
  background: #FFF5F5;
  border-radius: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.unlock-text {
  font-size: 26rpx;
  color: #FF6B6B;
  margin-bottom: 20rpx;
}

/* 功能介绍（可折叠） */
.pet-intro {
  width: 100%;
  box-sizing: border-box;
  margin-top: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.intro-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
}

.intro-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.intro-arrow {
  font-size: 22rpx;
  color: #999;
}

.intro-body {
  padding: 0 30rpx 24rpx;
}

.intro-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 弹窗样式 */
.unlock-modal,
.edit-name-modal {
  padding: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}

/* ==================== 宠物动画样式 ==================== */

/* 宠物待机浮动动画 */
.pet-mood-animate {
  animation: petFloat 3s ease-in-out infinite;
}

/* 宠物跳跃动画（投喂时） */
.pet-bounce {
  animation: petBounce 0.6s ease !important;
}

/* 宠物摇晃动画（摸摸时） */
.pet-shake {
  animation: petShake 0.5s ease !important;
}

/* 爱心泡泡 */
.heart-bubbles {
  position: absolute;
  top: 60rpx;
  left: 0;
  right: 0;
  height: 200rpx;
  pointer-events: none;
  z-index: 10;
}

.heart-bubble {
  position: absolute;
  font-size: 40rpx;
  animation: heartFloat 1.5s ease-out forwards;
  opacity: 0;
}

.heart-bubble.h1 {
  left: 30%;
  animation-delay: 0s;
}

.heart-bubble.h2 {
  left: 50%;
  animation-delay: 0.2s;
  font-size: 50rpx;
}

.heart-bubble.h3 {
  left: 65%;
  animation-delay: 0.4s;
}

/* 食物飞入动画 */
.food-fly {
  position: absolute;
  top: 40rpx;
  right: 60rpx;
  z-index: 20;
  animation: foodFlyIn 0.8s ease-out forwards;
}

.food-emoji {
  font-size: 60rpx;
}

/* 闪光特效 */
.sparkle-effect {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 30;
}

.sparkle {
  position: absolute;
  font-size: 50rpx;
  animation: sparkleAnim 1s ease-out forwards;
  opacity: 0;
}

.sparkle.s1 {
  top: 20rpx;
  left: 20%;
  animation-delay: 0s;
}

.sparkle.s2 {
  top: 60rpx;
  right: 20%;
  animation-delay: 0.15s;
  font-size: 60rpx;
}

.sparkle.s3 {
  top: 100rpx;
  left: 40%;
  animation-delay: 0.3s;
}

.sparkle.s4 {
  top: 40rpx;
  left: 60%;
  animation-delay: 0.1s;
  font-size: 40rpx;
}

/* 按钮Pop动画 */
.btn-pop {
  animation: btnPop 0.3s ease !important;
}

/* 好感度进度条发光动画 */
.affection-fill {
  position: relative;
}

.affection-fill::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 20rpx;
  height: 100%;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 0 8rpx 8rpx 0;
  animation: shimmer 2s ease-in-out infinite;
}

/* ==================== 关键帧动画 ==================== */

/* 宠物待机浮动 */
@keyframes petFloat {
  0%, 100% {
    transform: translateY(0rpx);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

/* 宠物跳跃（投喂） */
@keyframes petBounce {
  0% { transform: translateY(0) scale(1); }
  30% { transform: translateY(-40rpx) scale(1.1); }
  50% { transform: translateY(0) scale(0.95); }
  70% { transform: translateY(-15rpx) scale(1.02); }
  100% { transform: translateY(0) scale(1); }
}

/* 宠物摇晃（摸摸） */
@keyframes petShake {
  0%, 100% { transform: rotate(0deg) scale(1); }
  15% { transform: rotate(-8deg) scale(1.05); }
  30% { transform: rotate(8deg) scale(1.05); }
  45% { transform: rotate(-5deg) scale(1.03); }
  60% { transform: rotate(5deg) scale(1.03); }
  75% { transform: rotate(-2deg) scale(1.01); }
}

/* 爱心上浮消失 */
@keyframes heartFloat {
  0% {
    opacity: 1;
    transform: translateY(0) scale(0.5);
  }
  50% {
    opacity: 0.8;
    transform: translateY(-80rpx) scale(1.2);
  }
  100% {
    opacity: 0;
    transform: translateY(-160rpx) scale(0.8);
  }
}

/* 食物飞入 */
@keyframes foodFlyIn {
  0% {
    opacity: 1;
    transform: translateX(100rpx) translateY(-50rpx) scale(0.3) rotate(30deg);
  }
  60% {
    opacity: 1;
    transform: translateX(-20rpx) translateY(10rpx) scale(1.2) rotate(-10deg);
  }
  100% {
    opacity: 0;
    transform: translateX(0) translateY(0) scale(1) rotate(0deg);
  }
}

/* 闪光特效 */
@keyframes sparkleAnim {
  0% {
    opacity: 0;
    transform: scale(0) rotate(0deg);
  }
  50% {
    opacity: 1;
    transform: scale(1.5) rotate(180deg);
  }
  100% {
    opacity: 0;
    transform: scale(0.5) rotate(360deg);
  }
}

/* 按钮Pop */
@keyframes btnPop {
  0% { transform: scale(1); }
  50% { transform: scale(0.85); }
  100% { transform: scale(1); }
}

/* 进度条微光 */
@keyframes shimmer {
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

/* 宠物卡片进入动画 */
.pet-card {
  animation: cardEnter 0.5s ease-out;
}

@keyframes cardEnter {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
