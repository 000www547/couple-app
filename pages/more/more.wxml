<!--pages/more/more.wxml-->
<view class="container">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="header-title">更多功能</text>
    <text class="header-subtitle">发现情侣互动新玩法</text>
  </view>

  <!-- 亲密度卡片 -->
  <view class="intimacy-card" bindtap="showIntimacyHelp">
    <view class="intimacy-left">
      <view class="intimacy-icon">
        <text>💕</text>
      </view>
      <view class="intimacy-info">
        <text class="intimacy-label">亲密度</text>
        <text class="intimacy-desc">点击查看如何提升</text>
      </view>
    </view>
    <view class="intimacy-right">
      <text class="intimacy-level">Lv.{{intimacyLevel}}</text>
      <text class="intimacy-count">{{intimacy}}点</text>
    </view>
  </view>

  <!-- 功能入口网格 -->
  <view class="feature-grid">
    <view class="feature-card" bindtap="goToPoke">
      <view class="feature-icon-wrap poke">
        <text class="feature-icon">💗</text>
      </view>
      <text class="feature-name">戳一戳</text>
      <text class="feature-desc">长按发送心跳 +2</text>
    </view>

    <view class="feature-card" bindtap="showAbout">
      <view class="feature-icon-wrap about-bg">
        <text class="feature-icon">💝</text>
      </view>
      <text class="feature-name">关于</text>
      <text class="feature-desc">了解泡芙空间</text>
    </view>
  </view>

  <!-- 小提示 -->
  <view class="tip-section">
    <text class="tip-text">这里会陆续添加更多情侣互动小功能哦~</text>
  </view>
</view>