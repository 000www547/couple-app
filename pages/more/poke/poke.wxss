/* pages/more/poke/poke.wxss */
.container {
  min-height: 100vh;
  background: #FFF5F7;
  padding-bottom: 40rpx;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.header-title {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
}

/* 发送区域 */
.send-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
}

.send-tip {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 50rpx;
}

/* 大爱心按钮 */
.heart-btn-wrap {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.heart-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9EB5, #FF6B9D);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 40rpx rgba(255, 107, 157, 0.35);
  transition: transform 0.15s;
  position: relative;
}

.heart-btn.pressing {
  transform: scale(1.05);
}

.heart-btn.sending {
  animation: heartbeat 0.4s ease-in-out;
}

@keyframes heartbeat {
  0% { transform: scale(1); }
  25% { transform: scale(1.2); }
  50% { transform: scale(0.95); }
  75% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

.heart-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.heart-icon {
  font-size: 80rpx;
  filter: grayscale(1) brightness(2);
}

.hold-text {
  margin-top: 30rpx;
  font-size: 26rpx;
  color: #999;
}

/* 进度条 */
.progress-ring {
  width: 300rpx;
  height: 6rpx;
  background: #eee;
  border-radius: 3rpx;
  margin-top: 30rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #FFB6C1, #FF69B4);
  border-radius: 3rpx;
  transition: width 0.1s linear;
}

/* 最近记录 */
.history-section {
  margin: 0 40rpx;
}

.history-title {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 20rpx;
  display: block;
}

.history-list {
  max-height: 50vh;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.history-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.me-tag {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.history-text {
  font-size: 28rpx;
  color: #333;
}

.history-time {
  font-size: 22rpx;
  color: #bbb;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.empty-tip, .loading-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #ccc;
  font-size: 26rpx;
}