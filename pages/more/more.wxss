/* pages/more/more.wxss */
.container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 40rpx 30rpx;
}

/* 页面标题 */
.page-header {
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.header-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 功能网格 */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.feature-card {
  background: #1A1A1A;
  border-radius: 28rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s;
  position: relative;
  overflow: hidden;
}

.feature-card::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 150rpx;
  height: 150rpx;
  background: radial-gradient(circle, rgba(255, 107, 157, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.feature-card:active {
  transform: scale(0.97);
}

.feature-card.placeholder {
  opacity: 0.5;
  background: #2D2D2D;
}

.feature-icon-wrap {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.feature-icon-wrap.poke {
  background: linear-gradient(135deg, #FF6B9D, #FF8FB0);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.3);
}

.feature-icon-wrap.placeholder-bg {
  background: rgba(255, 255, 255, 0.08);
}

/* 分区标题 */
.section-title {
  margin: 40rpx 0 20rpx;
}

.section-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

/* 关于区域（固定在底部） */
.about-section {
  margin-top: 60rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.about-section:active {
  opacity: 0.8;
}

.about-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.about-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.about-arrow {
  font-size: 32rpx;
  color: #999;
}

.feature-icon {
  font-size: 56rpx;
}

.feature-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 8rpx;
  position: relative;
  z-index: 1;
}

.feature-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  position: relative;
  z-index: 1;
}

/* 提示 */
.tip-section {
  margin-top: 60rpx;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: #bbb;
}

/* 亲密度卡片 */
.intimacy-card {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB0 100%);
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.25);
}

.intimacy-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.intimacy-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.intimacy-icon text {
  font-size: 40rpx;
}

.intimacy-info {
  display: flex;
  flex-direction: column;
}

.intimacy-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.intimacy-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.intimacy-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.intimacy-level {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.intimacy-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}
