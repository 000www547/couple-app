/* pages/profile/profile.wxss */
.user-card {
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  border-radius: 20rpx;
  padding: 50rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.avatar-section {
  position: relative;
}

.avatar-btn {
  padding: 0;
  background: transparent;
  border: none;
}

.avatar-btn::after {
  border: none;
}

.avatar-large {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.role-badge {
  position: absolute;
  bottom: 0;
  right: -10rpx;
  background: #FFD700;
  color: #333;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin: 20rpx 0;
}

.user-card van-button {
  margin-top: 10rpx;
}

.partner-section, .bind-section, .stats-section, .invite-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.section-title, .stats-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.partner-card {
  display: flex;
  align-items: center;
}

.partner-info {
  margin-left: 20rpx;
}

.partner-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.partner-status {
  font-size: 24rpx;
  color: #87CEEB;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  color: #FFB6C1;
  font-weight: bold;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.edit-modal, .bind-modal {
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}

.bind-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  border: 1rpx solid #eee;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.picker {
  border: 1rpx solid #eee;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
}

/* 邀请码区域 */
.invite-section {
  margin-top: 20rpx;
}

.invite-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.invite-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.invite-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.invite-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.invite-code-box {
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  margin-bottom: 20rpx;
}

.invite-code {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 4rpx;
}

/* 关系列表 */
.relationship-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.unbind-btn {
  font-size: 24rpx;
  color: #999;
}

.relationship-list {
  margin-top: 10rpx;
}

.relationship-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.relationship-item:last-child {
  border-bottom: none;
}

.relationship-left {
  display: flex;
  align-items: center;
}

.avatar-small {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.relationship-info {
  margin-left: 16rpx;
}

.relationship-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.relationship-tags {
  margin-top: 8rpx;
}

/* 关系类型选择 */
.relation-type-group {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.relation-type-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  margin: 0 6rpx;
  border: 1rpx solid #eee;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  background: #fff;
}

.relation-type-btn.active {
  background: #FFB6C1;
  color: #fff;
  border-color: #FFB6C1;
}

/* 解除关系弹窗 */
.unbind-modal {
  padding: 40rpx;
}

.unbind-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 30rpx;
}

.unbind-highlight {
  display: block;
  color: #ff4d4f;
}

.unbind-warning {
  background: #fff2f0;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.unbind-warning text {
  color: #ff4d4f;
  font-size: 24rpx;
}

.mt-20 {
  margin-top: 20rpx;
}
