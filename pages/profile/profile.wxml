<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-large" src="{{userInfo.avatar || '/assets/icons/user.png'}}"/>
      </button>
      <text class="role-badge" wx:if="{{userInfo.role}}">{{userInfo.role === 'boyfriend' ? '小哥哥' : '小姐姐'}}</text>
    </view>
    <text class="nickname">{{userInfo.nickname || '未设置昵称'}}</text>
    <van-button size="small" round color="#FF6B9D" plain bindtap="showEditModal">编辑资料</van-button>
  </view>

  <!-- 邀请码展示 -->
  <view class="invite-section" wx:if="{{userInfo && userInfo.inviteCode}}">
    <view class="invite-card">
      <view class="invite-header">
        <text class="invite-title">我的邀请码</text>
        <text class="invite-desc">分享给 TA 绑定关系</text>
      </view>
      <view class="invite-code-box">
        <text class="invite-code">{{userInfo.inviteCode}}</text>
      </view>
      <van-button color="#FF6B9D" size="small" round bindtap="copyInviteCode">复制邀请码</van-button>
    </view>
  </view>

  <!-- 伴侣信息 -->
  <view class="partner-section" wx:if="{{partnerInfo}}">
    <view class="section-header-row">
      <view class="section-title">我的另一半</view>
      <text class="unbind-btn" bindtap="showUnbindModal">解除关系</text>
    </view>
    <view class="partner-card">
      <image class="avatar" src="{{partnerInfo.avatar || '/assets/icons/user.png'}}"/>
      <view class="partner-info">
        <text class="partner-name">{{partnerInfo.nickname || 'TA'}}</text>
        <text class="partner-status">已绑定</text>
      </view>
    </view>
  </view>

  <!-- 绑定伴侣 -->
  <view class="bind-section" wx:if="{{!partnerInfo}}">
    <van-button color="#1A1A1A" block round bindtap="showBindModal">绑定另一半</van-button>
  </view>

  <!-- 关系列表 -->
  <view class="relationship-section" wx:if="{{relationships.length > 0}}">
    <view class="section-title">我的关系</view>
    <view class="relationship-list">
      <view class="relationship-item" wx:for="{{relationships}}" wx:key="partnerId">
        <view class="relationship-left">
          <image class="avatar-small" src="/assets/icons/user.png"/>
          <view class="relationship-info">
            <text class="relationship-name">{{item.partnerName || 'TA'}}</text>
            <view class="relationship-tags">
              <van-tag type="primary" size="small">{{item.typeName}}</van-tag>
              <van-tag type="warning" size="small" wx:if="{{item.status === 'pending_unbind'}}">待确认</van-tag>
            </view>
          </view>
        </view>
        <view class="relationship-actions">
          <van-button size="mini" type="danger" plain wx:if="{{item.status === 'pending_unbind' && item.unbindRequestBy !== userInfo._openid}}" bindtap="confirmUnbind" data-partnerid="{{item.partnerId}}">确认解除</van-button>
        </view>
      </view>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-section">
    <view class="stats-title">我们的数据</view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-number">{{stats.moments}}</text>
        <text class="stat-label">甜蜜时刻</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.wishes}}</text>
        <text class="stat-label">心愿总数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.completedWishes}}</text>
        <text class="stat-label">已完成</text>
      </view>
    </view>
  </view>

  <!-- 编辑资料弹窗 -->
  <van-popup show="{{showEditModal}}" round position="bottom" bind:close="hideEditModal">
    <view class="edit-modal">
      <view class="modal-title">编辑资料</view>
      
      <view class="input-group">
        <text class="input-label">昵称</text>
        <input class="input" placeholder="输入昵称" value="{{editForm.nickname}}" bindinput="onNicknameInput"/>
      </view>

      <view class="input-group">
        <text class="input-label">在一起的日子（选填）</text>
        <picker mode="date" value="{{editForm.anniversaryDate}}" bindchange="onAnniversaryChange" end="{{today}}">
          <view class="picker">
            {{editForm.anniversaryDate || '选择日期'}}
          </view>
        </picker>
      </view>

      <view class="input-group">
        <text class="input-label">我的生日（选填，可保密）</text>
        <picker mode="date" value="{{editForm.birthday}}" bindchange="onBirthdayChange" end="{{today}}">
          <view class="picker">
            {{editForm.birthday || '选择日期或留空'}}
          </view>
        </picker>
      </view>

      <van-button color="#1A1A1A" block round bindtap="saveProfile">保存</van-button>
    </view>
  </van-popup>

  <!-- 绑定弹窗 -->
  <van-popup show="{{showBindModal}}" round position="bottom" bind:close="hideBindModal">
    <view class="bind-modal">
      <view class="modal-title">绑定关系</view>
      <view class="bind-desc">让 TA 在个人中心生成邀请码，然后在这里输入绑定</view>

      <!-- 关系类型选择 -->
      <view class="relation-type-group">
        <view class="relation-type-btn {{selectedRelationType === 'couple' ? 'active' : ''}}" bindtap="setRelationType" data-type="couple">
          情侣
        </view>
        <view class="relation-type-btn {{selectedRelationType === 'bestie' ? 'active' : ''}}" bindtap="setRelationType" data-type="bestie">
          闺蜜/兄弟
        </view>
        <view class="relation-type-btn {{selectedRelationType === 'family' ? 'active' : ''}}" bindtap="setRelationType" data-type="family">
          家人
        </view>
        <view class="relation-type-btn {{selectedRelationType === 'custom' ? 'active' : ''}}" bindtap="setRelationType" data-type="custom">
          自定义
        </view>
      </view>

      <!-- 自定义关系名称输入（仅选择"自定义"时显示） -->
      <view class="input-group" wx:if="{{selectedRelationType === 'custom'}}">
        <input class="input" placeholder="请输入你们的关系名称" value="{{customRelationName}}" bindinput="onCustomRelationInput"/>
      </view>

      <view class="input-group">
        <input class="input" placeholder="输入对方邀请码" value="{{partnerCode}}" bindinput="onCodeInput"/>
      </view>

      <van-button color="#1A1A1A" block round bindtap="bindPartner">绑定</van-button>
    </view>
  </van-popup>

  <!-- 解除关系弹窗 -->
  <van-popup show="{{showUnbindModal}}" round position="bottom" bind:close="hideUnbindModal">
    <view class="unbind-modal">
      <view class="modal-title">解除关系</view>
      <view class="unbind-desc">
        解除关系后：
        <text class="unbind-highlight">1. 双方共同数据将被清除</text>
        <text class="unbind-highlight">2. 甜蜜时刻、心愿清单将被删除</text>
        <text class="unbind-highlight">3. 需要重新绑定才能再次使用</text>
      </view>
      <view class="unbind-warning">
        <text>⚠️ 此操作不可逆，请谨慎操作</text>
      </view>
      <van-button type="danger" block round bindtap="requestUnbind">发起解除</van-button>
      <van-button plain block round bindtap="hideUnbindModal" class="mt-20">取消</van-button>
    </view>
  </van-popup>
</view>
