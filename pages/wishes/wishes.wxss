/* pages/wishes/wxss */

/* ==================== 进度区域 - 深色卡片 ==================== */
.progress-section {
  background: #1A1A1A;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.progress-value {
  font-size: 32rpx;
  color: #FF6B9D;
  font-weight: 700;
}

/* ==================== 心愿列表 ==================== */
.wishes-list {
  height: calc(100vh - 280rpx);
  padding: 0 20rpx;
}

.wish-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.wish-item.completed .wish-title {
  text-decoration: line-through;
  color: #999;
}

.wish-checkbox {
  margin-right: 20rpx;
  margin-top: 5rpx;
}

.wish-content {
  flex: 1;
}

.wish-creator {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #FF6B9D;
  background: rgba(255, 107, 157, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
}

.wish-title {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.wish-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.wish-meta {
  margin-top: 10rpx;
}

.delete-btn {
  color: #ccc;
  margin-left: 15rpx;
  padding: 10rpx;
}

/* ==================== 添加按钮 ==================== */
.fab {
  position: fixed;
  bottom: 50rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1A1A1A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

/* ==================== 弹窗 ==================== */
.add-modal {
  padding: 40rpx;
  background: #fff;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 40rpx;
  color: #1A1A1A;
}

.input-group {
  margin-bottom: 30rpx;
}

.input {
  background: #F8F8F8;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1A1A1A;
}

.textarea {
  background: #F8F8F8;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 100%;
  height: 120rpx;
  box-sizing: border-box;
  color: #1A1A1A;
}

.share-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  position: relative;
  z-index: 100;
}

.empty-tip, .loading-tip {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 26rpx;
}
