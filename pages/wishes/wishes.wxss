/* pages/wishes/wishes.wxss */
.progress-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-label {
  font-size: 28rpx;
  color: #333;
}

.progress-value {
  font-size: 28rpx;
  color: #FFB6C1;
  font-weight: bold;
}

.wishes-list {
  height: calc(100vh - 280rpx);
  padding: 0 20rpx;
}

.wish-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 15rpx;
  padding: 25rpx;
  margin-bottom: 15rpx;
}

.wish-item.completed .wish-title {
  text-decoration: line-through;
  color: #999;
}

.wish-checkbox {
  margin-right: 20rpx;
  margin-top: 5rpx;
}

.wish-content {
  flex: 1;
}

.wish-title {
  font-size: 28rpx;
  color: #333;
}

.wish-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.wish-meta {
  margin-top: 10rpx;
}

.delete-btn {
  color: #999;
  margin-left: 15rpx;
}

.fab {
  position: fixed;
  bottom: 50rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #87CEEB, #4682B4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(135, 206, 235, 0.5);
}

.add-modal {
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input {
  border: 1rpx solid #eee;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.textarea {
  border: 1rpx solid #eee;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  height: 120rpx;
  box-sizing: border-box;
}

.share-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  font-size: 28rpx;
  color: #333;
}

.empty-tip, .loading-tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 26rpx;
}
