<!--pages/wishes/wishes.wxml-->
<view class="container">
  <!-- 进度条 -->
  <view class="progress-section">
    <view class="progress-header">
      <text class="progress-label">完成进度</text>
      <text class="progress-value">{{completedCount || 0}}/{{wishes.length}}</text>
    </view>
    <van-progress percentage="{{progressPercent}}" color="#FF6B9D" track-color="rgba(255,255,255,0.1)" stroke-width="8rpx" rounded />
  </view>

  <!-- Tab切换 -->
  <view class="custom-tabs">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="onTabChange" data-type="all">全部</view>
    <view class="tab-item {{activeTab === 'my' ? 'active' : ''}}" bindtap="onTabChange" data-type="my">我的</view>
    <view class="tab-item {{activeTab === 'shared' ? 'active' : ''}}" bindtap="onTabChange" data-type="shared">共同</view>
  </view>

      <!-- 心愿列表 -->
  <scroll-view scroll-y class="wishes-list">
    <view class="wish-item {{item.isCompleted ? 'completed' : ''}}" wx:for="{{wishes}}" wx:key="_id">
      <view class="wish-checkbox" bindtap="toggleComplete" data-id="{{item._id}}">
        <van-checkbox value="{{item.isCompleted}}" disabled="{{true}}" checked-color="#FF6B9D"/>
      </view>
      <view class="wish-content">
        <view class="wish-header">
          <text class="wish-title">{{item.title}}</text>
          <text class="wish-creator" wx:if="{{activeTab === 'all' || activeTab === 'shared'}}">{{item.creatorNickname === currentUser.nickname || item.userId === currentUser._openid ? '我' : item.creatorNickname || '匿名用户'}}</text>
        </view>
        <text class="wish-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <view class="wish-meta" wx:if="{{item.isShared}}">
          <van-tag type="warning" size="small">共同心愿</van-tag>
        </view>
      </view>
      <van-icon name="delete" class="delete-btn" bindtap="deleteWish" data-id="{{item._id}}"/>
    </view>

    <view class="empty-tip" wx:if="{{wishes.length === 0 && !loading}}">
      <text>还没有心愿，快来许个愿吧~</text>
    </view>

    <view class="loading-tip" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </scroll-view>

  <!-- 添加按钮 -->
  <view class="fab" bindtap="showAddModal">
    <van-icon name="plus" size="40rpx" color="#fff"/>
  </view>

  <!-- 添加心愿弹窗 -->
  <van-popup show="{{showAddModal}}" round position="bottom" bind:close="hideAddModal">
    <view class="add-modal">
      <view class="modal-title">添加心愿</view>
      
      <view class="input-group">
        <input class="input" placeholder="输入心愿" value="{{newWish.title}}" bindinput="onTitleInput"/>
      </view>

      <view class="input-group">
        <textarea class="textarea" placeholder="添加描述（选填）" value="{{newWish.description}}" bindinput="onDescInput"/>
      </view>

      <view class="share-option" bindtap="onShareChange">
        <text>设为共同心愿</text>
        <view class="custom-switch {{newWish.isShared ? 'active' : ''}}">
          <view class="custom-switch-dot"></view>
        </view>
      </view>

      <van-button color="#1A1A1A" block round bindtap="addWish">保存</van-button>
    </view>
  </van-popup>
</view>
