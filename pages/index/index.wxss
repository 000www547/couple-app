/* pages/index/index.wxss */

/* ==================== 页面头部 ==================== */
.page-header {
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: 2rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* ==================== 主卡片 - 深色风格 ==================== */
.hero-card {
  background: #1A1A1A;
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  color: #fff;
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
}

.hero-card::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -10%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 107, 157, 0.12) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-card::after {
  content: '';
  position: absolute;
  bottom: -20%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(135, 206, 235, 0.08) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.hero-label {
  font-size: 26rpx;
  opacity: 0.6;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.hero-number {
  font-size: 120rpx;
  font-weight: 700;
  line-height: 1.1;
  background: linear-gradient(135deg, #fff 0%, #FFB6C1 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-unit {
  font-size: 32rpx;
  opacity: 0.7;
  margin-top: 8rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  opacity: 0.6;
  margin-top: 16rpx;
}

.hero-hint {
  position: absolute;
  bottom: 20rpx;
  right: 24rpx;
  z-index: 2;
}

.hero-hint text {
  font-size: 20rpx;
  opacity: 0.4;
}

.hero-empty .hero-number {
  opacity: 0.3;
  -webkit-text-fill-color: rgba(255, 255, 255, 0.3);
}

/* ==================== 统计卡片行 ==================== */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-card {
  flex: 1;
  background: #1A1A1A;
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(255, 107, 157, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.stat-card-number {
  font-size: 44rpx;
  font-weight: 700;
  color: #FF6B9D;
  line-height: 1.2;
  position: relative;
  z-index: 1;
}

.stat-card-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
  position: relative;
  z-index: 1;
}

/* ==================== 次卡片（生日倒计时） ==================== */
.sub-card {
  background: #2D2D2D;
  border-radius: 24rpx;
  padding: 32rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.sub-content {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.sub-label {
  font-size: 26rpx;
  opacity: 0.6;
}

.sub-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #FF6B9D;
  line-height: 1;
}

.sub-unit {
  font-size: 26rpx;
  opacity: 0.6;
}

/* ==================== 纪念日区域 ==================== */
.anniversary-section {
  margin-top: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: #1A1A1A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.anniversary-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.anniversary-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.anniversary-left {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.anniversary-title {
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 600;
}

.anniversary-date {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.anniversary-who {
  font-size: 22rpx;
  color: #FF6B9D;
  margin-top: 6rpx;
  font-weight: 500;
}

.anniversary-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.countdown {
  font-size: 26rpx;
  color: #FF6B9D;
  font-weight: 600;
  background: rgba(255, 107, 157, 0.08);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.countdown.past {
  color: #999;
  background: #F5F5F5;
}

.delete-icon {
  color: #ccc;
  padding: 10rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* ==================== 弹窗 ==================== */
.add-modal {
  padding: 40rpx;
  background: #fff;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 40rpx;
  color: #1A1A1A;
}

.input-group {
  margin-bottom: 30rpx;
}

.input {
  background: #F8F8F8;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1A1A1A;
}

.picker {
  background: #F8F8F8;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1A1A1A;
}

.input-tip {
  font-size: 24rpx;
  color: #FF6B9D;
  margin-top: 12rpx;
  padding: 0 10rpx;
}

.type-group {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
  gap: 16rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666;
  background: #F8F8F8;
}

.type-btn.active {
  background: #1A1A1A;
  color: #fff;
  border-color: #1A1A1A;
}

.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
