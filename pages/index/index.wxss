/* pages/index/index.wxss */

/* 主卡片 - 渐变背景 */
.hero-card {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  color: #fff;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 182, 193, 0.4);
  position: relative;
  overflow: hidden;
}

.hero-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.hero-card::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.hero-label {
  font-size: 32rpx;
  opacity: 0.95;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.hero-number {
  font-size: 120rpx;
  font-weight: bold;
  line-height: 1.2;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.hero-unit {
  font-size: 36rpx;
  opacity: 0.95;
  margin-top: 10rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  margin-top: 16rpx;
  font-style: italic;
}

.hero-hint {
  position: absolute;
  bottom: 16rpx;
  right: 20rpx;
  z-index: 2;
}

.hero-hint text {
  font-size: 20rpx;
  opacity: 0.7;
}

.hero-empty .hero-number {
  opacity: 0.6;
}

/* 次卡片 */
.sub-card {
  background: linear-gradient(135deg, #87CEEB 0%, #4169E1 100%);
  border-radius: 30rpx;
  padding: 40rpx;
  color: #fff;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(135, 206, 235, 0.4);
}

.sub-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.sub-label {
  font-size: 28rpx;
  opacity: 0.95;
  margin-bottom: 10rpx;
}

.sub-number {
  font-size: 80rpx;
  font-weight: bold;
  line-height: 1.2;
}

.sub-unit {
  font-size: 32rpx;
  opacity: 0.95;
}

/* 纪念日区域 */
.anniversary-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.anniversary-list {
  margin-top: 20rpx;
}

.anniversary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.anniversary-item:last-child {
  border-bottom: none;
}

.anniversary-left {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.anniversary-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.anniversary-date {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.anniversary-who {
  font-size: 22rpx;
  color: #FF69B4;
  margin-top: 6rpx;
  font-weight: 500;
}

.anniversary-right {
  display: flex;
  align-items: center;
}

.countdown {
  font-size: 26rpx;
  color: #FF69B4;
  font-weight: 500;
  margin-right: 20rpx;
}

.countdown.past {
  color: #999;
}

.delete-icon {
  color: #ccc;
  padding: 10rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 弹窗 */
.add-modal {
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.input-group {
  margin-bottom: 30rpx;
}

.input {
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  background: #fafafa;
}

.picker {
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

.input-tip {
  font-size: 24rpx;
  color: #FF69B4;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.type-group {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
  gap: 16rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border: 2rpx solid #eee;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
  transition: all 0.3s;
}

.type-btn.active {
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(255, 182, 193, 0.4);
}

.pin-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 30rpx;
  color: #666;
  font-size: 28rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-30 {
  margin-top: 30rpx;
}
