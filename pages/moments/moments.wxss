/* pages/moments/moments.wxss */
.moments-list {
  height: 100vh;
  padding-bottom: 120rpx;
}

.moment-item {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.moment-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.delete-btn {
  color: #999;
}

.moment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.moment-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.image-wrapper {
  width: 210rpx;
  height: 210rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.moment-image {
  width: 100%;
  height: 100%;
}

.moment-footer {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.like-btn {
  display: flex;
  align-items: center;
}

.like-count {
  margin-left: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.fab {
  position: fixed;
  bottom: 50rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 182, 193, 0.5);
}

.post-modal {
  padding: 30rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.content-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 1rpx solid #eee;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.selected-images {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.image-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  color: #fff;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add-image-btn {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 26rpx;
}

.add-image-btn text {
  margin-left: 10rpx;
}

.empty-tip, .loading-tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 26rpx;
}

/* 评论样式 */
.moment-footer .action-btn {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.comment-count {
  margin-left: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.comments-section {
  background: #fafafa;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.comments-list {
  margin-bottom: 20rpx;
}

.comment-item {
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-main {
  display: flex;
  align-items: flex-start;
}

.comment-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.comment-body {
  flex: 1;
}

.comment-user {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.comment-reply {
  font-size: 24rpx;
  color: #FF69B4;
}

.comment-content {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-top: 6rpx;
  line-height: 1.5;
}

.comment-actions {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  padding-left: 65rpx;
}

.comment-time {
  font-size: 20rpx;
  color: #999;
  flex: 1;
}

.reply-btn {
  font-size: 24rpx;
  color: #FF69B4;
  margin-right: 20rpx;
}

.comment-delete {
  color: #ccc;
  font-size: 24rpx;
}

.no-comments {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 20rpx 0;
}

.comment-input-area {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
  border: 1rpx solid #eee;
}

.comment-input {
  flex: 1;
  font-size: 26rpx;
  background: transparent;
}
