/* pages/moments/moments.wxss */

.moments-list {
  height: 100vh;
  padding-bottom: 120rpx;
}

/* ==================== 动态卡片 - 深色风格 ==================== */
.moment-item {
  background: #1A1A1A;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.moment-item::before {
  content: '';
  position: absolute;
  top: -20%;
  right: -10%;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(255, 107, 157, 0.06) 0%, transparent 70%);
  border-radius: 50%;
}

.moment-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4rpx;
}

.delete-btn {
  color: rgba(255, 255, 255, 0.3);
  padding: 10rpx;
}

.moment-content {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.7;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.moment-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.image-wrapper {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.moment-image {
  width: 100%;
  height: 100%;
}

/* ==================== 底部操作栏 ==================== */
.moment-footer {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  position: relative;
  z-index: 1;
}

.action-btn {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.like-count, .comment-count {
  margin-left: 10rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ==================== 发布按钮 ==================== */
.fab {
  position: fixed;
  bottom: 50rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1A1A1A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

/* ==================== 发布弹窗 ==================== */
.post-modal {
  padding: 30rpx;
  background: #fff;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.content-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  background: #F8F8F8;
  color: #1A1A1A;
}

.selected-images {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.image-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  color: #fff;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add-image-btn {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 26rpx;
}

.add-image-btn text {
  margin-left: 10rpx;
}

.empty-tip, .loading-tip {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* ==================== 评论区域 ==================== */
.comments-section {
  background: rgba(255, 255, 255, 0.04);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  position: relative;
  z-index: 1;
}

.comments-list {
  margin-bottom: 20rpx;
}

.comment-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-main {
  display: flex;
  align-items: flex-start;
}

.comment-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.comment-body {
  flex: 1;
}

.comment-user {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.comment-reply {
  font-size: 24rpx;
  color: #FF6B9D;
}

.comment-content {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
  line-height: 1.5;
}

.comment-actions {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  padding-left: 60rpx;
}

.comment-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
  flex: 1;
}

.reply-btn {
  font-size: 24rpx;
  color: #FF6B9D;
  margin-right: 20rpx;
}

.comment-delete {
  color: rgba(255, 255, 255, 0.3);
  font-size: 24rpx;
}

.no-comments {
  text-align: center;
  color: rgba(255, 255, 255, 0.3);
  font-size: 24rpx;
  padding: 20rpx 0;
}

/* 评论输入框 */
.comment-input-area {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 30rpx;
  padding: 10rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.comment-input {
  flex: 1;
  font-size: 26rpx;
  background: transparent;
  color: #fff;
  padding: 10rpx;
}

.comment-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}
