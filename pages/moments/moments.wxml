<!--pages/moments/moments.wxml-->
<view class="container">
  <!-- 动态列表 -->
  <scroll-view scroll-y class="moments-list">
    <view class="moment-item" wx:for="{{moments}}" wx:key="_id">
      <!-- 用户信息 -->
      <view class="moment-header">
        <image class="avatar" src="{{userInfos[item.userId].avatar || '/assets/icons/user.png'}}"/>
        <view class="user-info">
          <text class="nickname">{{userInfos[item.userId].nickname || '匿名用户'}}</text>
          <text class="time">{{item.createTime}}</text>
        </view>
        <van-icon name="delete" class="delete-btn" wx:if="{{currentUser && item.userId === currentUser._openid}}" bindtap="deleteMoment" data-id="{{item._id}}"/>
      </view>

      <!-- 内容 -->
      <view class="moment-content">
        <text>{{item.content}}</text>
      </view>

      <!-- 图片 -->
      <view class="moment-images" wx:if="{{item.images && item.images.length > 0}}">
        <view class="image-wrapper" wx:for="{{item.images}}" wx:for-item="img" wx:key="index" bindtap="previewImage" data-url="{{img}}">
          <image class="moment-image" src="{{img}}" mode="aspectFill"/>
        </view>
      </view>

      <!-- 点赞和评论按钮 -->
      <view class="moment-footer">
        <view class="action-btn" bindtap="likeMoment" data-id="{{item._id}}">
          <van-icon name="like" color="{{item.likedBy && item.likedBy.indexOf(currentUser._openid) > -1 ? '#FFB6C1' : '#999'}}"/>
          <text class="like-count">{{item.likes || 0}}</text>
        </view>
        <view class="action-btn" bindtap="toggleComments" data-id="{{item._id}}" data-index="{{index}}">
          <van-icon name="chat-o" color="{{item.showComments ? '#FFB6C1' : '#999'}}"/>
          <text class="comment-count">{{item.comments.length || 0}}</text>
        </view>
      </view>

      <!-- 评论区域 -->
      <view class="comments-section" wx:if="{{item.showComments}}">
        <!-- 评论列表 -->
        <view class="comments-list" wx:if="{{item.comments && item.comments.length > 0}}">
          <view class="comment-item" wx:for="{{item.comments}}" wx:for-item="comment" wx:key="_id">
            <view class="comment-main">
              <image class="comment-avatar" src="{{item.commentUserInfos[comment.userId].avatar || '/assets/icons/user.png'}}"/>
              <view class="comment-body">
                <text class="comment-user">{{item.commentUserInfos[comment.userId].nickname || '匿名用户'}}</text>
                <text class="comment-reply" wx:if="{{comment.replyTo}}"> 回复 @{{item.commentUserInfos[comment.replyToUserId].nickname || '匿名用户'}}</text>
                <text class="comment-content">{{comment.content}}</text>
              </view>
            </view>
            <view class="comment-actions">
              <text class="comment-time">{{comment.createTime}}</text>
              <text class="reply-btn" bindtap="showReplyInput" data-momentid="{{item._id}}" data-commentid="{{comment._id}}" data-userid="{{comment.userId}}" data-index="{{index}}">回复</text>
              <van-icon name="delete" class="comment-delete" wx:if="{{comment.userId === currentUser._openid}}" bindtap="deleteComment" data-commentid="{{comment._id}}" data-momentid="{{item._id}}"/>
            </view>
          </view>
        </view>
        <view class="no-comments" wx:else>
          <text>还没有评论，快来抢沙发~</text>
        </view>

        <!-- 评论输入框 -->
        <view class="comment-input-area">
          <input class="comment-input" placeholder="{{replyingTo ? '回复 @' + replyingTo : '写评论...'}}" value="{{commentInputs[item._id]}}" bindinput="onCommentInput" data-momentid="{{item._id}}"/>
          <van-button size="small" color="#FF6B9D" round bindtap="submitComment" data-momentid="{{item._id}}">发送</van-button>
        </view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{moments.length === 0 && !loading}}">
      <text>还没有甜蜜时刻，快来记录吧~</text>
    </view>

    <view class="loading-tip" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </scroll-view>

  <!-- 发布按钮 -->
  <view class="fab" bindtap="showPostModal">
    <van-icon name="plus" size="40rpx" color="#fff"/>
  </view>

  <!-- 发布弹窗 -->
  <van-popup show="{{showPostModal}}" round position="bottom" bind:close="hidePostModal">
    <view class="post-modal">
      <view class="modal-header">
        <text class="modal-title">发布甜蜜时刻</text>
        <van-icon name="close" bindtap="hidePostModal"/>
      </view>

      <textarea class="content-input" placeholder="记录你们的甜蜜时刻..." value="{{newMoment.content}}" bindinput="onContentInput" maxlength="500"/>

      <!-- 已选图片 -->
      <view class="selected-images" wx:if="{{newMoment.images.length > 0}}">
        <view class="image-item" wx:for="{{newMoment.images}}" wx:key="index">
          <image class="preview-img" src="{{item}}" mode="aspectFill"/>
          <van-icon name="clear" class="remove-btn" bindtap="removeImage" data-index="{{index}}"/>
        </view>
      </view>

      <view class="modal-footer">
        <view class="add-image-btn" bindtap="chooseImages">
          <van-icon name="photograph" size="40rpx"/>
          <text>添加图片</text>
        </view>
        <van-button color="#1A1A1A" round size="small" bindtap="postMoment">发布</van-button>
      </view>
    </view>
  </van-popup>
</view>
