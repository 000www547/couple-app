/** app.wxss **/
page {
  --primary-pink: #FFB6C1;
  --primary-blue: #87CEEB;
  --primary-yellow: #FFD700;
  --text-color: #333333;
  --text-light: #666666;
  --bg-color: #f8f8f8;
  --white: #ffffff;
  
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-color);
}

.container {
  padding: 20rpx;
}

/* 主题色卡片 */
.theme-card {
  background: linear-gradient(135deg, var(--primary-pink), var(--primary-blue));
  border-radius: 20rpx;
  padding: 40rpx;
  color: var(--white);
  box-shadow: 0 8rpx 20rpx rgba(255, 182, 193, 0.3);
}

.theme-card-blue {
  background: linear-gradient(135deg, var(--primary-blue), #6BB3D9);
}

.theme-card-yellow {
  background: linear-gradient(135deg, var(--primary-yellow), #FFC107);
}

/* 通用按钮样式 */
.btn-primary {
  background: var(--primary-pink);
  color: var(--white);
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

.btn-secondary {
  background: var(--primary-blue);
  color: var(--white);
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 20rpx;
}

.title-small {
  font-size: 28rpx;
  color: var(--text-light);
}

/* flex 辅助类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }

.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 圆形头像 */
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-large {
  width: 150rpx;
  height: 150rpx;
}

.avatar-small {
  width: 60rpx;
  height: 60rpx;
}

/* 背景图片 */
.bg-pink { background-color: var(--primary-pink); }
.bg-blue { background-color: var(--primary-blue); }
.bg-yellow { background-color: var(--primary-yellow); }
